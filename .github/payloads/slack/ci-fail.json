{
  "blocks": [
    {
      "type": "header",
      "text": {
        "type": "plain_text",
        "text": ":rotating_light: CI Failure",
        "emoji": true
      }
    },
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": "*<${{ env.RUN_URL }}|${{ env.REPO_NAME }} — ${{ env.WORKFLOW_NAME }}>*"
      }
    },
    {
      "type": "section",
      "fields": [
        { "type": "mrkdwn", "text": "*Branch:*\n${{ env.HEAD_BRANCH }}" },
        { "type": "mrkdwn", "text": "*Commit:*\n`${{ env.HEAD_SHA }}`" },
        { "type": "mrkdwn", "text": "*Event:*\n${{ env.EVENT_NAME }}" },
        { "type": "mrkdwn", "text": "*Conclusion:*\n${{ env.CONCLUSION }}" },
        { "type": "mrkdwn", "text": "*Run:*\n<${{ env.RUN_URL }}|${{ env.RUN_ID }}>" }
      ]
    }
  ]
}
